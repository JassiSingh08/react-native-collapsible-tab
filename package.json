{
  "name": "react-native-collapsible-tab",
  "version": "0.1.0",
  "description": "Collapsible header tab view for React Native with per-tab scroll memory and a jump-free header. First-class FlatList, ScrollView, SectionList, FlashList v2 and LegendList support.",
  "author": "Jassi Singh (https://github.com/JassiSingh08)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JassiSingh08/react-native-collapsible-tab.git"
  },
  "homepage": "https://github.com/JassiSingh08/react-native-collapsible-tab#readme",
  "bugs": {
    "url": "https://github.com/JassiSingh08/react-native-collapsible-tab/issues"
  },
  "source": "./src/index.ts",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./flash-list": {
      "source": "./src/flash-list.ts",
      "import": {
        "types": "./lib/typescript/module/src/flash-list.d.ts",
        "default": "./lib/module/flash-list.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/flash-list.d.ts",
        "default": "./lib/commonjs/flash-list.js"
      }
    },
    "./legend-list": {
      "source": "./src/legend-list.ts",
      "import": {
        "types": "./lib/typescript/module/src/legend-list.d.ts",
        "default": "./lib/module/legend-list.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/legend-list.d.ts",
        "default": "./lib/commonjs/legend-list.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "README.md",
    "MIGRATION.md",
    "LICENSE",
    "!**/__tests__",
    "!**/.*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bob build",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "collapsible",
    "tabs",
    "tab-view",
    "collapsible-tabs",
    "collapsible-header",
    "flashlist",
    "legendlist",
    "reanimated",
    "expo"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@legendapp/list": ">=2.0.0",
    "@shopify/flash-list": ">=2.0.0",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-pager-view": ">=6.0.0",
    "react-native-reanimated": ">=3.6.0"
  },
  "peerDependenciesMeta": {
    "@legendapp/list": {
      "optional": true
    },
    "@shopify/flash-list": {
      "optional": true
    }
  },
  "devDependencies": {
    "@legendapp/list": "^3.0.4",
    "@shopify/flash-list": "^2.0.0",
    "@types/react": "^19.0.0",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-builder-bob": "^0.40.6",
    "react-native-gesture-handler": "^2.25.0",
    "react-native-pager-view": "^6.7.0",
    "react-native-reanimated": "^3.17.4",
    "typescript": "^5.8.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  },
  "sideEffects": false
}
